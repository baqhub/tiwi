{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "files.autoSave": "onFocusChange",
  "oxc.typeAware": true,
  "oxc.fmt.configPath": "./vite.config.ts",
  "oxc.path.oxfmt": ".vscode/oxfmt-with-vp-version.sh",
  "oxc.path.oxlint": "node_modules/vite-plus/bin/oxlint",
  "oxc.path.tsgolint": "node_modules/.bin/tsgolint",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.preferences.importModuleSpecifierEnding": "js",
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "mdx.server.enable": false,
  "[mdx][md]": {
    "editor.wordWrap": "on"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.classFunctions": ["tw", "tiwi", "tiwi\\.[a-z-]+"],
  "movets.skipWarning": true,
  "files.exclude": {
    "**/.yarn/releases": true,
    "**/.yarn/unplugged": true,
    "**/.yarn/install-state.gz": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/*.tsbuildinfo": true,
    "**/.next": true,
    "**/out": true
  },
  "search.exclude": {
    "**/.yarn": true
  },
  "cSpell.words": [
    "abortable",
    "baqhub",
    "Canonicalization",
    "canonicalize",
    "codomain",
    "docsearch",
    "domutils",
    "Fediverse",
    "forwardable",
    "heroicons",
    "httpcli",
    "idempotency",
    "idempotently",
    "keychain",
    "Linkify",
    "marsidev",
    "mathilde",
    "oxfmt",
    "oxlint",
    "pipeable",
    "pressable",
    "proxied",
    "proxying",
    "quentez",
    "rehype",
    "rolldown",
    "svgr",
    "tailwindcss",
    "tanstack",
    "tiwi",
    "tsdown",
    "tsgolint",
    "typeof",
    "unfollow",
    "unicity",
    "uniwind",
    "unoptimized",
    "viteplus",
    "voidzero"
  ]
}
